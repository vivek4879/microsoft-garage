generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id            String      @id @default(cuid())
  source        String
  caption       String?
  scheduledAt   DateTime?
  status        String      @default("pending")
  aiScore       Float?
  createdAt     DateTime    @default(now())
  postedAt      DateTime?
  rawContent    String?
  screenshotUrl String?
  sourceTitle   String
  sourceUrl     String
  analytics     Analytics[]
}

model Settings {
  id             String   @id @default(cuid())
  aiProvider     String   @default("openai")
  aiApiKey       String?
  postFrequency  Int      @default(2)
  telegramChatId String?
  igAccessToken  String?
  igPageId       String?
  tavilyApiKey   String?
  subreddits     String   @default("[\"funny\",\"AskReddit\",\"mildlyinteresting\"]")
  bestPostTimes  String   @default("[9,12,18]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Analytics {
  id       String   @id @default(cuid())
  postId   String
  likes    Int      @default(0)
  comments Int      @default(0)
  reach    Int      @default(0)
  savedAt  DateTime @default(now())
  post     Post     @relation(fields: [postId], references: [id])
}
