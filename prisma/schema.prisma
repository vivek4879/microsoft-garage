// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id            String       @id @default(cuid())
  source        String       // "reddit" or "twitter"
  sourceUrl     String
  sourceTitle   String
  rawContent    String?      // raw JSON of the post + comments
  screenshotUrl String?
  caption       String?
  aiScore       Float?
  status        String       @default("pending")
  scheduledAt   DateTime?
  postedAt      DateTime?
  createdAt     DateTime     @default(now())
  analytics     Analytics[]
}



model Settings {
  id              String  @id @default(cuid())
  aiProvider      String  @default("openai")    // openai, anthropic, or gemini
  aiApiKey        String?
  postFrequency   Int     @default(2)            // posts per day
  telegramChatId  String?
  igAccessToken   String?
  igPageId        String?
  tavilyApiKey    String?
  subreddits      String  @default("[\"funny\",\"AskReddit\",\"mildlyinteresting\"]")
  bestPostTimes   String  @default("[9,12,18]")  // hours of day (JSON array)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Analytics {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  likes     Int      @default(0)
  comments  Int      @default(0)
  reach     Int      @default(0)
  savedAt   DateTime @default(now())
}
